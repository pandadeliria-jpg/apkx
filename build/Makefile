src/vm.s: src/vm.cpp.s
.PHONY : src/vm.s

# target to generate assembly for a file
src/vm.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/apkx.dir/build.make CMakeFiles/apkx.dir/src/vm.cpp.s
.PHONY : src/vm.cpp.s

